# Nereus backend — environment variables
# Copy this file to `.env` and fill in your keys. `.env` is gitignored.

# --- LLM (the classifier brain) ---------------------------------------------
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Model is configurable on purpose — free-tier models get rotated, so never
# hardcode one. Override here without touching code.
GEMINI_MODEL=gemini-2.5-flash

# --- News source ------------------------------------------------------------
# Get a free key at https://newsdata.io/register
NEWSDATA_API_KEY=

# --- Tuning (optional; sensible defaults in code) ---------------------------
# How many items to bundle into one LLM classification call (free-tier lever).
CLASSIFY_BATCH_SIZE=10
# Cache time-to-live in seconds for /search and /feed.
CACHE_TTL_SEARCH=300
CACHE_TTL_FEED=900
