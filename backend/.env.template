# Nereus backend — environment variables
# Copy this file to `.env` and fill in your keys. `.env` is gitignored.

# --- LLM (the classifier brain) ---------------------------------------------
# Which provider to use: gemini | groq. Swap with this one line (no code change).
# Default is groq: its free daily token budget is the binding constraint of the whole
# app, and the llama-3.1-8b-instant model has the most headroom (see below).
LLM_PROVIDER=groq

# Groq — get a free key at https://console.groq.com/keys
# Token-per-DAY budget is what runs out first. llama-3.1-8b-instant gives 500k/day (~5x
# the 70b model) at on-par accuracy on our eval (macro-F1 0.792 vs 0.797) — see MODEL_CARD.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Gemini (alternative) — get a free key at https://aistudio.google.com/apikey
# Model is configurable on purpose — free-tier models get rotated, so never hardcode one.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# --- News source ------------------------------------------------------------
# Get a free key at https://newsdata.io/register
NEWSDATA_API_KEY=

# --- Reddit source (opinion-rich) -------------------------------------------
# Create a free app (type: "web app") at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=nereus/0.1 (by u/your_username)

# --- YouTube source (video) -------------------------------------------------
# Enable "YouTube Data API v3" at https://console.cloud.google.com and make an API key.
# Note: search costs 100 units of a 10k/day budget -> ~100 searches/day. Cache hard.
YOUTUBE_API_KEY=

# --- Tuning (optional; sensible defaults in code) ---------------------------
# How many items to bundle into one LLM classification call (free-tier lever).
CLASSIFY_BATCH_SIZE=10
# Cache time-to-live in seconds for /search and /feed.
CACHE_TTL_SEARCH=300
CACHE_TTL_FEED=900
# Shorter TTL used when classification failed wholesale (LLM rate-limited): the
# degraded result self-heals quickly instead of serving "Unrated" for the full TTL.
CACHE_TTL_DEGRADED=30
# Stale-while-revalidate: how long past expiry a cached result may still be served
# while a background refresh runs. Visitors get instant (slightly old) results instead
# of waiting 4-30s on the pipeline.
CACHE_STALE_WINDOW=21600

# Max items returned per request. Bounds the per-request classification cost so a search
# stays inside the LLM's per-minute token window (keeps cold loads fast).
RETRIEVE_MAX_ITEMS=30

# --- Security / deploy -------------------------------------------------------
# Allowed CORS origins (comma-separated). In prod, set this to your deployed frontend URL.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Per-IP rate limit on /search and /feed: max requests per window (seconds). Protects the
# shared free-tier budgets from a single client draining them.
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW=60
